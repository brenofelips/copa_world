# ── Required ──────────────────────────────────────────────────────────────────
# API-Football key — get yours at https://www.api-football.com
API_FOOTBALL_KEY=your_api_football_key

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_IMAGE=apache/kafka:3.7.0
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_AUTO_CREATE_TOPICS_ENABLE=false
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_CLUSTER_ID=example_cluster_id
KAFKA_HOST_PORT=9092
KAFKA_TOPIC=match-events
KAFKA_TOPIC_PARTITIONS=2
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_BROKERS=kafka:9092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_IMAGE=redis:7-alpine
REDIS_HOST_PORT=6379
REDIS_ADDR=redis:6379

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=copaworld
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres:5432/copaworld?sslmode=disable
DATABASE_REPLICA_URL=postgres://postgres:postgres@postgres-replica-1:5432/copaworld?sslmode=disable

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_IMAGE=nginx:alpine
NGINX_HOST_PORT=80

# ── Ingestion API ─────────────────────────────────────────────────────────────
INGESTION_API_PORT=8081

# ── Web Server ────────────────────────────────────────────────────────────────
WEB_SERVER_PORT=8080
WEB_SERVER_HOST_PORT=8080

# ── Data Provider ─────────────────────────────────────────────────────────────
INGESTION_URL=http://nginx/events
POLL_INTERVAL=30s
SCHEDULE_INTERVAL=1h
LEAGUE_ID=1
SEASON=2026

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_HOST_PORT=3000
NEXT_PUBLIC_WEB_SERVER_URL=http://localhost:8080
