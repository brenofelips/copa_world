# ── Required ──────────────────────────────────────────────────────────────────
# API-Football key — get yours at https://www.api-football.com
API_FOOTBALL_KEY=your_key_here

# ── Data Provider ─────────────────────────────────────────────────────────────
# INGESTION_URL=http://nginx/events
# POLL_INTERVAL=30s
# SCHEDULE_INTERVAL=1h   # How often to fetch the full day schedule
# LEAGUE_ID=1            # 1 = FIFA World Cup (api-football.com)
# SEASON=2026

# ── Ingestion API ─────────────────────────────────────────────────────────────
# PORT=8081
# KAFKA_BROKERS=kafka:9092

# ── Score Service ─────────────────────────────────────────────────────────────
# KAFKA_BROKERS=kafka:9092
# REDIS_ADDR=redis:6379

# ── Event Service ─────────────────────────────────────────────────────────────
# KAFKA_BROKERS=kafka:9092
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/copaworld?sslmode=disable

# ── Web Server ────────────────────────────────────────────────────────────────
# PORT=8080
# REDIS_ADDR=redis:6379
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/copaworld?sslmode=disable
# DATABASE_REPLICA_URL=postgres://postgres:postgres@postgres-replica-1:5432/copaworld?sslmode=disable

# ── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_WEB_SERVER_URL=http://localhost:8080
